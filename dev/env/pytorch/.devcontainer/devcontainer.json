// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-dockerfile
{
	"name": "pytorch",

	"build": {
		// Set the run context to one level up instead of inside the .devcontainer folder.
		"context": ".",
		// Set path to the Dockerfile.
		"dockerfile": "./Dockerfile"
	},
	
	// Features to add to the dev container. More info: https://containers.dev/features.
	"features": {
		"ghcr.io/eliises/devcontainer-features/devcontainers-cli:1": {},
		"ghcr.io/devcontainers/features/docker-in-docker:2": {
			"version": "latest",
			"enableNonRootDocker": "true",
			"moby": "false"
		}
	},

	"mounts": [
		"source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
	],

	// Configure tool-specific properties.
	"customizations": {
		// Configure properties specific to VS Code.
		"vscode": {
			// Add the IDs of extensions to be installed when the container is created.
			"extensions": [
				"ms-python.python",
				"ms-toolsai.jupyter",
				"github.copilot",
				"github.copilot-chat",
				"ms-python.autopep8",
				"ms-azuretools.vscode-docker",
				"ms-python.isort",
				"chrisdias.vscode-opennewinstance",
				"ms-python.debugpy",
				"ms-vscode.makefile-tools",
				"donjayamanne.githistory",
				"tomoki1207.pdf",
				"analytic-signal.preview-html",
				"modular-mojotools.vscode-mojo"
			]
		}
	},

	"runArgs": [
		"--add-host=host.docker.internal:host-gateway",
		"--env-file=.devcontainer/.env",
		"-e", "DISPLAY=host.docker.internal:0.0",
		"--gpus", "all",
		"--ulimit", "memlock=-1",
		"--ulimit", "stack=67108864",
		"--shm-size=16g"
	],

	// Add environment variables for X11
	"remoteEnv": {
		"DISPLAY": "host.docker.internal:0.0",
		"LIBGL_ALWAYS_INDIRECT": "1"
	},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Uncomment the next line to run commands after the container is created.
	"postCreateCommand": "git config --global user.name $GITLAB_USER_NAME && git config --global user.email $GITLAB_USER_EMAIL && cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit && cp scripts/commit-msg .git/hooks/commit-msg && chmod +x .git/hooks/commit-msg",

	"workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/${localWorkspaceFolderBasename},type=bind,consistency=cached",
	"workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

	// Uncomment to connect as an existing user other than the container default. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "devcontainer"
}